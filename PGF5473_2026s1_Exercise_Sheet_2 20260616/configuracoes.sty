\RequirePackage{xparse}

% Controle global para exibicao das resolucoes.
% Uso tipico no main.tex:
%   \OcultarResolucoes
% ou
%   \MostrarResolucoes
\newif\ifmostrarresolucoes
\mostrarresolucoestrue
\newcommand{\OcultarResolucoes}{\mostrarresolucoesfalse}
\newcommand{\MostrarResolucoes}{\mostrarresolucoestrue}

\NewDocumentEnvironment{resolucao}{ O{Resolucao} +b }
{
    \ifmostrarresolucoes
        \par
        \medskip
        \noindent\textbf{#1}\par
        \begingroup
        \color{corResolucao}
        % \fontfamily{tgcursor}
        % \fontfamily{qag}
        % \fontfamily{phv}
        #2
        \par
        \endgroup
        \vspace{\baselineskip}
    \fi
}
{}

\NewDocumentEnvironment{ignorado}{ O{} +b }
{
    \par
    \medskip
    \begingroup
    \color{corIgnorado}
    % \fontfamily{tgcursor}
    % \fontfamily{qag}
    % \fontfamily{phv}
    #2
    \par
    \endgroup
    \vspace{\baselineskip}
}
{}

% Ambiente de exercicio com identificador textual livre.
% Esta e a interface mais flexivel para o caso em que o exercicio nao segue uma
% numeracao puramente sequencial.
%
% Exemplos de uso:
%   \begin{exercicio}
%   \begin{exercicio}[Exercicio 3]
%   \begin{exercicio}[Boyd, Nonlinear Optics, cap. 1, problema 3]
%   \begin{exercicio}[Capitulo 22.3, secao D]
\newcounter{exercicio}
\newcommand{\nomeexercicio}{Exercicio}

\NewDocumentEnvironment{exercicio}{ O{} +b }
{
    \par\medskip
    \refstepcounter{exercicio}
    \noindent\textbf{%
        \if\relax\detokenize{#1}\relax
            \nomeexercicio~\theexercicio
        \else
            #1
        \fi
    }\par
    \smallskip
    #2
    \par\medskip
}
{}

% Interface estruturada para exercicios com metadados.
% Esta alternativa e mais adequada quando o projeto precisa manter padrao entre
% fonte, capitulo, secao, problema, titulo e label.
%
% Exemplo de uso:
% \begin{exercicioinfo}[
%   fonte={Boyd, Nonlinear Optics},
%   capitulo={1},
%   secao={3},
%   problema={5},
%   titulo={Driven harmonic oscillator},
%   label={ex:boyd-1-3-5}
% ]
%   Enunciado...
% \end{exercicioinfo}
\ExplSyntaxOn
\tl_new:N \l__config_fonte_tl
\tl_new:N \l__config_capitulo_tl
\tl_new:N \l__config_secao_tl
\tl_new:N \l__config_problema_tl
\tl_new:N \l__config_titulo_tl
\tl_new:N \l__config_label_tl

\keys_define:nn { configuracoes/exercicio }
{
    fonte    .tl_set:N = \l__config_fonte_tl,
    capitulo .tl_set:N = \l__config_capitulo_tl,
    secao    .tl_set:N = \l__config_secao_tl,
    problema .tl_set:N = \l__config_problema_tl,
    titulo   .tl_set:N = \l__config_titulo_tl,
    label    .tl_set:N = \l__config_label_tl,
}

\cs_new_protected:Npn \__config_exercicio_reset:
{
    \tl_clear:N \l__config_fonte_tl
    \tl_clear:N \l__config_capitulo_tl
    \tl_clear:N \l__config_secao_tl
    \tl_clear:N \l__config_problema_tl
    \tl_clear:N \l__config_titulo_tl
    \tl_clear:N \l__config_label_tl
}

\cs_new:Npn \__config_exercicio_cabecalho:
{
    \tl_if_blank:NF \l__config_fonte_tl    { \textit{\l__config_fonte_tl} }
    \tl_if_blank:NF \l__config_capitulo_tl { \ifhmode\space\fi -- cap.~\l__config_capitulo_tl }
    \tl_if_blank:NF \l__config_secao_tl    { \ifhmode\space\fi -- sec.~\l__config_secao_tl }
    \tl_if_blank:NF \l__config_problema_tl { \ifhmode\space\fi -- prob.~\l__config_problema_tl }
    \tl_if_blank:NF \l__config_titulo_tl   { \ifhmode\space\fi -- \l__config_titulo_tl }
}

\NewDocumentEnvironment{exercicioinfo}{ O{} +b }
{
    \par\medskip
    \refstepcounter{exercicio}
    \__config_exercicio_reset:
    \keys_set:nn { configuracoes/exercicio } { #1 }
    \noindent\textbf{\nomeexercicio~\theexercicio}\par
    \smallskip
    \noindent\__config_exercicio_cabecalho:\par
    \tl_if_blank:NF \l__config_label_tl { \label{\l__config_label_tl} }
    \smallskip
    #2
    \par\medskip
}
{}
\ExplSyntaxOff

